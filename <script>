document.getElementById('forgotPassword').addEventListener('click', function(){
    const email = prompt("Inserisci la tua email per ripristinare la password:");
    if(!email) return alert("Email non inserita!");

    const user = users.find(u => u.email === email);
    if(!user){
        return alert("Email non trovata!");
    }

    // Genera codice temporaneo (simulazione email)
    const resetCode = Math.floor(100000 + Math.random() * 900000);
    alert("Simulazione invio email: codice di reset generato: " + resetCode);

    const enteredCode = prompt("Inserisci il codice ricevuto via email:");
    if(parseInt(enteredCode) !== resetCode){
        return alert("Codice errato! Password non modificata.");
    }

    const newPass = prompt("Inserisci la nuova password:");
    if(!newPass) return alert("Password non modificata!");

    user.password = newPass;
    localStorage.setItem('users', JSON.stringify(users));
    alert("Password aggiornata con successo! Ora puoi fare il login con la nuova password.");

    document.getElementById('loginEmail').value = user.email;
    document.getElementById('loginPassword').value = "";
});
